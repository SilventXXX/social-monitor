# 复制为 .env 并填写实际值

# 数据库（默认 SQLite）
# DATABASE_URL=sqlite+aiosqlite:///./social_monitor.db

# X (Twitter) API - https://developer.x.com
# TWITTER_BEARER_TOKEN=your_bearer_token
# TWITTER_USER_ID=your_user_id

# Reddit API - https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# REDDIT_USER_AGENT=SocialMonitor/1.0

# 通知 - 邮件
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# NOTIFY_EMAIL=your_email@gmail.com

# 通知 - Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# 通知 - Webhook（可选）
# WEBHOOK_URL=https://your-webhook.com/notify

# AI 评分 - Kimi API（填写后开启 AI 相关性评分）
# KIMI_API_KEY=sk-kimi-xxxxxxxx

# 通知 - 飞书自定义机器人
# 1. 在飞书群聊 → 设置 → 群机器人 → 添加机器人 → 自定义机器人
# 2. 复制 Webhook 地址填入下方
# 3. 若开启「签名校验」安全方式，将密钥填入 FEISHU_SECRET
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# FEISHU_SECRET=your_secret_key

# 轮询间隔（分钟）
# POLL_INTERVAL_MINUTES=15
